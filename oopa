                            -- Update dual pump (respect locks)
                            if not multi1IsLocked() then mSlot[1].stockId=numId; multi1StockIdInput.Text=tostring(numId) end
                            if not multi2IsLocked() then mSlot[2].stockId=numId; multi2StockIdInput.Text=tostring(numId) end
                            if multiPage.Visible then
                                multiStatusLabel.TextColor3=C.teal
                                multiStatusLabel.Text="Stock detected!\nS1: "..(tostring(mSlot[1].stockId or "—")).."  ·  S2: "..(tostring(mSlot[2].stockId or "—"))
                            end
                        end)
                    end
                end
            end
            return oldNamecall(self, ...)
        end
        if newcclosure and type(newcclosure)=="function" then callback=newcclosure(callback) end
        oldNamecall = hookmetamethod(game, "__namecall", callback)
    end)

    if not hookOk then
        warn("[StonksHub] hookmetamethod failed: "..tostring(hookErr).." — auto stock detection disabled."); return
    end
    print("[StonksHub] Stock auto-detection hooked successfully.")
end)

