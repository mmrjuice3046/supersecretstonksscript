local KNIT_PATH = {"Packages","_Index","sleitnick_knit@1.7.0","knit","Services","Stocks","RF"}
local function getStocksRF_direct()
    local node = Svc.RS
    for _, name in ipairs(KNIT_PATH) do node=node:WaitForChild(name) end
    return node
end

local function sellerSellStock()
    pcall(function() getStocksRF_direct():WaitForChild("MarketSellPoints"):InvokeServer(seller.stockId, seller.quantity) end)
    seller.count=seller.count+1
end

local function sellerStartExecution()
    if sellerThread then return end
    sellerThread = task.spawn(function()
        while seller.enabled do
            pcall(function()
                local priceLabel = player.PlayerGui.Main.Invest.Stock.Trading.Interface.Details.Price.TextLabel
                local price = tonumber(string.match(priceLabel.Text, "[%d%.]+"))
                if price and price>=seller.priceThreshold then
                    sellerSellStock()
                    sellerStatusLabel.TextColor3=C.amber; sellerStatusLabel.Text="Executed!  Sold: "..seller.count.."x\nStock: "..seller.stockId
                else
                    sellerStatusLabel.TextColor3=C.textMuted; sellerStatusLabel.Text="Waiting for Ᵽ"..seller.priceThreshold.."  ·  Sold: "..seller.count.."x\nStock: "..seller.stockId
                end
            end)
            task.wait(seller.interval)
        end
        sellerThread=nil
    end)
end

local function noTaxStartExecution()
    if noTax.thread then return end
    noTax.thread = task.spawn(function()
        while noTax.enabled do
            pcall(function()
                getStocksRF_direct():WaitForChild("MarketSellPoints"):InvokeServer(seller.stockId, 100)
                noTax.count=noTax.count+1
                sellerStatusLabel.TextColor3=C.teal; sellerStatusLabel.Text="No Tax sold x100!  Total: "..noTax.count.."x\nStock: "..tostring(seller.stockId)
            end)
            task.wait(seller.interval)
        end
        noTax.thread=nil
    end)
end

