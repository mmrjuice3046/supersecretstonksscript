local function loadOverview()
    dashSubL.Text="Refreshing..."
    statRefs["session"].valL.Text=tostring(sessionCount); statRefs["session"].valL.TextColor3=C.green
    if Config.universeId~="" then
        statRefs["univid"].valL.Text=Config.universeId; statRefs["univid"].valL.TextSize=11
        statRefs["univid"].subL.Text="Configured ✓"; statRefs["univid"].subL.TextColor3=C.green
    else
        statRefs["univid"].valL.Text="—"; statRefs["univid"].subL.Text="Open Config"; statRefs["univid"].subL.TextColor3=C.red
    end
    task.spawn(function()
        local count, err = countGPs()
        if err then statRefs["total"].valL.Text="—"
        else
            local startT=tick(); local conn
            conn=Svc.Run.Heartbeat:Connect(function()
                local pct=math.min((tick()-startT)/1.0,1)
                local eased=pct==1 and 1 or 1-math.pow(2,-10*pct)
                statRefs["total"].valL.Text=tostring(math.floor(eased*count))
                if pct>=1 then conn:Disconnect(); statRefs["total"].valL.Text=tostring(count) end
            end)
        end
        dashSubL.Text=os.date("%B %d, %Y").."  ·  dashboard"
    end)
end

