-- ── Tab switcher ─────────────────────────────────────────────────────────────
local pages = {}

local function switchTab(name)
    if name==currentTab then return end
    currentTab = name
    for key, pg in pairs(pages) do pg.Visible=(key==name) end
    for key, item in pairs(navItems) do
        local isNow = (key==name)
        tween(item.frame,{BackgroundColor3=isNow and C.navActive or C.sidebar, BackgroundTransparency=isNow and 0 or 1},0.28,Enum.EasingStyle.Quint)
        if isNow then
            item.bar.Size=UDim2.new(0,0,0,18); item.bar.BackgroundTransparency=0
            tween(item.bar,{Size=UDim2.new(0,3,0,18)},0.35,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
        else
            tween(item.bar,{Size=UDim2.new(0,0,0,18),BackgroundTransparency=1},0.2,Enum.EasingStyle.Quint,Enum.EasingDirection.In)
        end
        tween(item.iconL,{TextColor3=isNow and C.purpleLight or C.textMuted},0.25)
        tween(item.textL,{TextColor3=isNow and C.purpleLight or C.textMuted},0.25)
    end
    mainArea.CanvasPosition = Vector2.new(0,0)
end

