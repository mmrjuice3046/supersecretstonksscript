-- Full getStocksRF: tries direct path, then knit folder scan, then full descendant scan
local function getStocksRF()
    local stocksRF
    pcall(function() stocksRF=game:GetService("ReplicatedStorage").Packages._Index["sleitnick_knit@1.7.0"].knit.Services.Stocks.RF end)
    if stocksRF then return stocksRF end
    pcall(function()
        local indexFolder = game:GetService("ReplicatedStorage"):FindFirstChild("Packages") and game:GetService("ReplicatedStorage").Packages:FindFirstChild("_Index")
        if indexFolder then
            for _, child in ipairs(indexFolder:GetChildren()) do
                if child.Name:lower():find("sleitnick_knit") then
                    local stocks = child:FindFirstChild("Stocks", true)
                    local rf = stocks and stocks:FindFirstChild("RF")
                    if rf then stocksRF=rf; break end
                end
            end
        end
    end)
    if stocksRF then return stocksRF end
    pcall(function()
        for _, d in ipairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
            if d.Name=="Stocks" and d:FindFirstChild("RF") then stocksRF=d.RF; break end
        end
    end)
    return stocksRF
end

-- Discovers stock IDs from RF remotes, PlayerGui text, and RS value objects
local function findStockIds(stocksRF)
    local ids = {}
    -- From known trading state
    if seller.stockId and seller.stockId~=0 then ids[seller.stockId]=true end
    if buyer.stockId   then ids[buyer.stockId]=true end
    if mSlot[1].stockId then ids[mSlot[1].stockId]=true end
    if mSlot[2].stockId then ids[mSlot[2].stockId]=true end
    -- From RF remotes
    if stocksRF then
        for _, rfName in ipairs({"GetStocks","GetPortfolio","GetPlayerStocks"}) do
            local rf = stocksRF:FindFirstChild(rfName)
            if rf and rf:IsA("RemoteFunction") then
                pcall(function()
                    local data = rf:InvokeServer()
                    if typeof(data)=="table" then
                        for k, v in pairs(data) do
                            if tonumber(k) then ids[tonumber(k)]=true end
                            if typeof(v)=="table" then
                                for _, field in ipairs({"Id","id","StockId","stockId"}) do
                                    if v[field] then ids[tonumber(v[field])]=true end
                                end
                            end
                        end
                    end
                end)
            end
        end
    end
    -- From PlayerGui text labels
    pcall(function()
        for _, child in ipairs(player:WaitForChild("PlayerGui"):GetDescendants()) do
            if child:IsA("TextLabel") or child:IsA("TextButton") or child:IsA("TextBox") then
                local num = tonumber(child.Text:match("%d+"))
                if num and num>1000000 then ids[num]=true end
            end
            for _, v in pairs(child:GetAttributes()) do
                local num = tonumber(v)
                if num and num>1000000 then ids[num]=true end
            end
        end
    end)
    local list = {}
    for id in pairs(ids) do table.insert(list, id) end
    return list
end

