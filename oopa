    end)
    if not ok or not OpenSocket then
        warn("[StonksHub] OpenSocket remote not found — auto stock detection disabled."); return
    end
    if not hookmetamethod or type(hookmetamethod)~="function" then
        warn("[StonksHub] hookmetamethod not available — auto stock detection disabled."); return
    end
    if not getnamecallmethod or type(getnamecallmethod)~="function" then
        warn("[StonksHub] getnamecallmethod not available — auto stock detection disabled."); return
    end

    local oldNamecall
    local hookOk, hookErr = pcall(function()
        local callback = function(self, ...)
            local args = {...}
            local ok2, method = pcall(getnamecallmethod)
            if not ok2 then method=nil end
            if self==OpenSocket and method=="InvokeServer" then
