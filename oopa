-- ── Drag ─────────────────────────────────────────────────────────────────────
local drag = { active=false, start=nil, origin=nil }
local function onDragBegan(pos)  drag.active=true;  drag.start=pos; drag.origin=mainFrame.Position end
local function onDragMoved(pos)
    if not drag.active then return end
    local d = pos - drag.start
    mainFrame.Position = UDim2.new(drag.origin.X.Scale, drag.origin.X.Offset+d.X, drag.origin.Y.Scale, drag.origin.Y.Offset+d.Y)
end
local function onDragEnded() drag.active=false end

titleBar.InputBegan:Connect(function(inp,gp)
    if gp then return end
    if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then onDragBegan(inp.Position) end
end)
titleBar.InputChanged:Connect(function(inp,gp) if not gp and inp.UserInputType==Enum.UserInputType.Touch then onDragMoved(inp.Position) end end)
titleBar.InputEnded:Connect(function(inp,gp)   if not gp and inp.UserInputType==Enum.UserInputType.Touch then onDragEnded() end end)
Svc.UIS.InputChanged:Connect(function(inp) if inp.UserInputType==Enum.UserInputType.MouseMovement then onDragMoved(inp.Position) end end)
Svc.UIS.InputEnded:Connect(function(inp)   if inp.UserInputType==Enum.UserInputType.MouseButton1  then onDragEnded() end end)

