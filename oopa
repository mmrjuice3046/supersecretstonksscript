local afgActive = false
local function doAFGSearch()
    if afgActive then return end
    afgActive=true; afgBtn.Text="Searching..."
    tween(afgBtn,{BackgroundColor3=C.purpleDark},0.15)
    afgStatusL.Text="Probing Roblox universe IDs..."; afgStatusL.TextColor3=C.textDim
    clearAFGResults()

    task.spawn(function()
        -- Probe random recent universe IDs (most are ~5–7.5B range for new games)
        local found, target, rounds, maxRounds = {}, 10, 0, 20
        local LOW, HIGH = 6000000000, 7500000000

        while #found<target and rounds<maxRounds do
            rounds=rounds+1
            afgStatusL.Text="Scanning... "..#found.."/"..target.." (batch "..rounds..")"

            local ids = {}
            for _ = 1, 50 do
                table.insert(ids, tostring(math.floor(LOW + math.random()*(HIGH-LOW))))
            end

            local url = "https://games.roblox.com/v1/games?universeIds="..table.concat(ids,",")
            local ok, res = pcall(httpRequest, {Url=url, Method="GET", Headers={}})

            if ok and res and res.StatusCode==200 then
                local dok, data = pcall(Svc.Http.JSONDecode, Svc.Http, res.Body)
                if dok and data and data.data then
                    for _, game in ipairs(data.data) do
                        local v = game.visits  or 1
                        local p = game.playing or 1
                        if v==0 and p==0 then
                            local dup=false
                            for _, f in ipairs(found) do
                                if f.placeId==(game.rootPlaceId or game.id) then dup=true; break end
                            end
                            if not dup then
                                table.insert(found, {placeId=game.rootPlaceId or game.id, name=game.name or "Unnamed"})
                                addAFGResult(game.rootPlaceId or game.id, game.name or "Unnamed", v, p)
                                afgStatusL.Text="Found "..#found.."/"..target.." so far..."
                                afgStatusL.TextColor3=C.teal
                            end
                        end
                    end
                end
            end
            task.wait(0.25)
        end

        if #found==0 then
            afgStatusL.Text="Nothing found — try again."; afgStatusL.TextColor3=C.red
        else
            afgStatusL.Text="Done! Found "..#found.." game(s) with 0 players & 0 visits."; afgStatusL.TextColor3=C.green
        end
        afgActive=false; afgBtn.Text="Search Now"; tween(afgBtn,{BackgroundColor3=C.tealStroke},0.15)
    end)
end

