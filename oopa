task.spawn(function()
    local claimInProgress = false
    while screenGui.Parent do
        task.wait(3)
        if autoCollectDividends then
            local stocksRF = getStocksRF()
            if stocksRF then
                if not claimInProgress then
                    claimInProgress = true
                    task.spawn(function()
                        local stockIds = findStockIds(stocksRF)
                        local successCount, totalCalls, errors = 0, 0, {}

                        -- Try ClaimAllDividends first
                        local claimAllRF = stocksRF:FindFirstChild("ClaimAllDividends")
                        if claimAllRF and claimAllRF:IsA("RemoteFunction") then
                            totalCalls=totalCalls+1
                            local ok, err = pcall(function() return claimAllRF:InvokeServer() end)
                            if ok then
                                successCount=successCount+1
                                adStatusL.TextColor3=C.green; adStatusL.Text="Claimed all dividends!"
                                acLog("✓ ClaimAllDividends — success", C.green)
                            else
                                table.insert(errors, "ClaimAll: "..tostring(err))
                            end
                        end

                        -- Try ClaimDividend per stock ID
                        local claimRF = stocksRF:FindFirstChild("ClaimDividend") or stocksRF:FindFirstChild("ClaimDividends")
                        if claimRF and claimRF:IsA("RemoteFunction") then
                            for _, id in ipairs(stockIds) do
                                totalCalls=totalCalls+1
                                local ok2, err2 = pcall(function() return claimRF:InvokeServer(id) end)
                                if ok2 then
                                    successCount=successCount+1
                                    acLog("✓ ClaimDividend ID "..tostring(id), C.green)
                                else
                                    table.insert(errors, "ID "..tostring(id)..": "..tostring(err2))
                                end
                            end
                        end

                        if totalCalls==0 then
                            adStatusL.Text="No claim remotes found."; adStatusL.TextColor3=C.red
                        elseif successCount>0 then
                            adStatusL.Text="Successfully claimed payout!"; adStatusL.TextColor3=C.green
