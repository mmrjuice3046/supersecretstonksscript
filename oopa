-- ── HTTP detection ──────────────────────────────────────────────────────────
local httpRequest
do
    local function safeGet(name)
        local ok, val = pcall(function() return getgenv and getgenv()[name] end)
        return ok and val or nil
    end
    local syn_ = safeGet("syn"); local http_ = safeGet("http"); local req_ = safeGet("request")
    if type(syn_) == "table" and type(syn_.request) == "function" then
        httpRequest = syn_.request
    elseif type(http_) == "table" and type(http_.request) == "function" then
        httpRequest = http_.request
    elseif type(req_) == "function" then
        httpRequest = req_
    else
        local g = safeGet("request")
        if type(g) == "function" then httpRequest = g end
    end
end

