-- ── GP Creator HTTP helpers ───────────────────────────────────────────────────
local function httpGet(url, headers)
    if not httpRequest then return nil, "No HTTP function" end
    local ok, res = pcall(httpRequest, { Url=url, Method="GET", Headers=headers or {} })
    if not ok then return nil, "pcall error: "..tostring(res) end
    if res.StatusCode < 200 or res.StatusCode >= 300 then
        local d = ""
        pcall(function()
            local e = HttpService:JSONDecode(res.Body)
            d = " ("..(e.message or e.error or res.StatusMessage or "")..")"
        end)
        return nil, "HTTP "..res.StatusCode..d
    end
    local decOk, decoded = pcall(HttpService.JSONDecode, HttpService, res.Body)
    if not decOk then return nil, "JSON parse error: "..tostring(res.Body):sub(1,80) end
    return decoded, nil
end

local function buildForm(fields)
    local b = "----GPBound"..tostring(os.time())
    local body = ""
    for k, v in pairs(fields) do
        body = body.."--"..b.."\r\nContent-Disposition: form-data; name=\""..k.."\"\r\n\r\n"..tostring(v).."\r\n"
    end
    return body.."--"..b.."--\r\n", "multipart/form-data; boundary="..b
end

local function httpPost(url, fields, extra)
    if not httpRequest then return nil, "No HTTP function" end
    local body, ct = buildForm(fields)
    local headers = { ["Content-Type"] = ct }
    if extra then for k,v in pairs(extra) do headers[k]=v end end
    local ok, res = pcall(httpRequest, { Url=url, Method="POST", Headers=headers, Body=body })
    if not ok then return nil, "pcall error: "..tostring(res) end
    if res.StatusCode < 200 or res.StatusCode >= 300 then
        local d = ""
        pcall(function()
            local e = HttpService:JSONDecode(res.Body)
            d = " — "..(e.message or e.error or "")
        end)
        return nil, "HTTP "..res.StatusCode..d
    end
    local decOk, decoded = pcall(HttpService.JSONDecode, HttpService, res.Body)
    if not decOk then return nil, "JSON parse error: "..tostring(res.Body):sub(1,80) end
    return decoded, nil
end

local function getExistingNames()
    local names, pt = {}, nil
    for _ = 1, 20 do
        local url = ROBLOX_API.."/game-passes/v1/universes/"..Config.universeId.."/game-passes/creator?pageSize=50"
        if pt then url = url.."&pageToken="..HttpService:UrlEncode(pt) end
        local data, err = httpGet(url, {["x-api-key"]=Config.apiKey})
        if err or not data then break end
        if data.gamePasses then for _,gp in ipairs(data.gamePasses) do names[gp.name]=true end end
        pt = data.nextPageToken
        if not pt or pt=="" then break end
    end
    return names
end

local function uniqueName(price)
    local ex = getExistingNames()
    local base = "Donate "..price.." Robux"
    if not ex[base] then return base end
    for i=1,999 do
        local c = "Donate "..price.."."..i.." Robux"
        if not ex[c] then return c end
    end
    return base.." "..tostring(os.time())
end

local function countGPs()
    if Config.universeId=="" then return nil, "No Universe ID" end
    local count, pt = 0, nil
    for _ = 1, 20 do
        local url = ROBLOX_API.."/game-passes/v1/universes/"..Config.universeId.."/game-passes/creator?pageSize=50"
        if pt then url=url.."&pageToken="..HttpService:UrlEncode(pt) end
        local data, err = httpGet(url, {["x-api-key"]=Config.apiKey})
        if err then return nil, err end
        if not data then return count, "No response" end
        if data.gamePasses then count=count+#data.gamePasses end
        pt = data.nextPageToken
        if not pt or pt=="" then break end
    end
    return count, nil
end

local function doCreate(price)
    if Config.apiKey==""     then return nil, "API Key not configured — open Config" end
    if Config.universeId=="" then return nil, "Universe ID not configured — open Config" end
    local name = uniqueName(price)
    local data, err = httpPost(
        ROBLOX_API.."/game-passes/v1/universes/"..Config.universeId.."/game-passes",
        { name=name, description="Donate "..price.." Robux", isForSale="true", price=tostring(price) },
        { ["x-api-key"]=Config.apiKey }
    )
    if err then return nil, err end
    return {
        gamePassId = data.gamePassId,
        name       = data.name or name,
        price      = price,
        link       = "https://www.roblox.com/game-pass/"..tostring(data.gamePassId)
    }, nil
end

