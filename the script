local function vToggle(parent, y)
    local enabled = false
    local btn = make("TextButton", {
        Size             = UDim2.new(1,-32,0,36),
        Position         = UDim2.new(0,16,0,y),
        BackgroundColor3 = C.disabledBg,
        TextColor3       = C.disabledText,
        Text             = "● DISABLED",
        TextSize         = 12,
        Font             = Enum.Font.GothamBold,
        BorderSizePixel  = 0,
    }, parent)
    corner(btn, 9)
    local stk = mkStroke(btn, C.disabledStk, 1)
    btn.MouseEnter:Connect(function()
        if enabled then tween(btn, {BackgroundColor3=Color3.fromRGB(13,60,55)}, 0.14)
        else            tween(btn, {BackgroundColor3=Color3.fromRGB(60,12,12)}, 0.14) end
    end)
    btn.MouseLeave:Connect(function()
        if enabled then tween(btn, {BackgroundColor3=C.enabledBg},  0.14)
        else            tween(btn, {BackgroundColor3=C.disabledBg}, 0.14) end
    end)
    local function setEnabled(on)
        enabled = on
        if on then
            tween(btn, {BackgroundColor3=C.enabledBg,  TextColor3=C.enabledText},  0.2)
            tween(stk, {Color=C.enabledStk},  0.2)
            btn.Text = "● ENABLED"
        else
            tween(btn, {BackgroundColor3=C.disabledBg, TextColor3=C.disabledText}, 0.2)
            tween(stk, {Color=C.disabledStk}, 0.2)
            btn.Text = "● DISABLED"
        end
    end
    return btn, setEnabled
end

local function vMaintainToggle(parent, x, y, linkedInput)
    local locked = false
    local btn = make("TextButton", {
        Size             = UDim2.new(0,98,0,24),
        Position         = UDim2.new(0,x,0,y),
        BackgroundColor3 = Color3.fromRGB(22,18,44),
        TextColor3       = C.textDim,
        Text             = "🔓 Maintain",
        TextSize         = 10,
        Font             = Enum.Font.GothamBold,
        BorderSizePixel  = 0,
        ZIndex           = 3,
    }, parent)
    corner(btn, 7)
    local stk = mkStroke(btn, C.border, 1)
    local function setLocked(on)
        locked = on
        if on then
            tween(btn, {BackgroundColor3=C.purpleDark, TextColor3=C.purpleLight}, 0.18)
            tween(stk, {Color=C.purple}, 0.18)
            btn.Text = "🔒 Locked"
            if linkedInput then
                linkedInput.TextEditable = false
                tween(linkedInput, {BackgroundColor3=Color3.fromRGB(14,14,22), TextColor3=C.textDim}, 0.18)
            end
        else
            tween(btn, {BackgroundColor3=Color3.fromRGB(22,18,44), TextColor3=C.textDim}, 0.18)
            tween(stk, {Color=C.border}, 0.18)
            btn.Text = "🔓 Maintain"
            if linkedInput then
                linkedInput.TextEditable = true
                tween(linkedInput, {BackgroundColor3=C.inputBg, TextColor3=C.text}, 0.18)
            end
        end
    end
    btn.MouseButton1Click:Connect(function() setLocked(not locked) end)
    btn.MouseEnter:Connect(function()
        if not locked then tween(btn, {BackgroundColor3=Color3.fromRGB(30,24,58)}, 0.12) end
    end)
    btn.MouseLeave:Connect(function()
        if not locked then tween(btn, {BackgroundColor3=Color3.fromRGB(22,18,44)}, 0.12) end
    end)
    local function isLocked() return locked end
    return btn, isLocked, setLocked
end

