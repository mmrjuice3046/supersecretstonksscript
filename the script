-- ── Page Switch Logic ─────────────────────────────────────────────────────────
local allPages = {}

local function switchTab(key)
    if key == currentTab then return end
    currentTab = key
    for _, pg in pairs(allPages) do pg.Visible = false end
    if allPages[key] then allPages[key].Visible = true end
    mainArea.CanvasPosition = Vector2.new(0,0)
    for k, item in pairs(navItems) do
        local isNow = (k == key)
        tween(item.frame,{
            BackgroundColor3=isNow and C.navActive or C.sidebar,
            BackgroundTransparency=isNow and 0 or 1
        },0.22,Enum.EasingStyle.Quint)
        item.bar.BackgroundTransparency = isNow and 0 or 1
        tween(item.iconL,{TextColor3=isNow and C.purpleLight or C.textMuted},0.22)
        tween(item.textL,{TextColor3=isNow and C.purpleLight or C.textMuted},0.22)
    end
end

