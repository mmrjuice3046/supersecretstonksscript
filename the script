local function getStocksRF()
    local stocksRF
    pcall(function() stocksRF=game:GetService("ReplicatedStorage").Packages._Index["sleitnick_knit@1.7.0"].knit.Services.Stocks.RF end)
    if stocksRF then return stocksRF end
    pcall(function()
        local rep=game:GetService("ReplicatedStorage")
        local idx=rep:FindFirstChild("Packages") and rep.Packages:FindFirstChild("_Index")
        if idx then
            for _,child in ipairs(idx:GetChildren()) do
                if child.Name:lower():find("sleitnick_knit") then
                    local stocks=child:FindFirstChild("Stocks",true)
                    local rf=stocks and stocks:FindFirstChild("RF")
                    if rf then stocksRF=rf; break end
                end
            end
        end
    end)
    if stocksRF then return stocksRF end
    pcall(function()
        for _,desc in ipairs(game:GetService("ReplicatedStorage"):GetDescendants()) do
            if desc.Name=="Stocks" and desc:FindFirstChild("RF") then stocksRF=desc.RF; break end
        end
    end)
    return stocksRF
end

