local afgActive=false
local function doAFGSearch()
    if afgActive then return end
    afgActive=true; afgBtn.Text="Searching..."; tween(afgBtn,{BackgroundColor3=C.purpleDark},0.15)
    afgStatusL.Text="Probing Roblox universe IDs..."; afgStatusL.TextColor3=C.textDim
    clearResultsList()
    task.spawn(function()
        local found={}; local target=10; local rounds=0; local maxRounds=20
        local LOW,HIGH=6000000000,7500000000
        while #found<target and rounds<maxRounds do
            rounds=rounds+1
            afgStatusL.Text="Scanning... found "..#found.."/"..target.." (batch "..rounds..")"
            local ids={}
            for _=1,50 do table.insert(ids,tostring(math.floor(LOW+math.random()*(HIGH-LOW)))) end
            local url="https://games.roblox.com/v1/games?universeIds="..table.concat(ids,",")
            local ok,res=pcall(httpRequest,{Url=url,Method="GET",Headers={}})
            if ok and res and res.StatusCode==200 then
                local decOk,data=pcall(HttpService.JSONDecode,HttpService,res.Body)
                if decOk and data and data.data then
                    for _,game in ipairs(data.data) do
                        local visits=game.visits or 1; local players=game.playing or 1
                        if visits==0 and players==0 then
                            local dup=false
                            for _,f in ipairs(found) do if f.placeId==(game.rootPlaceId or game.id) then dup=true; break end end
                            if not dup then
                                table.insert(found,{placeId=game.rootPlaceId or game.id,name=game.name or "Unnamed"})
                                addResult(game.rootPlaceId or game.id,game.name or "Unnamed",visits,players)
                                afgStatusL.Text="Found "..#found.."/"..target.." so far..."; afgStatusL.TextColor3=C.tealLight
                            end
                        end
                    end
                end
            end
            task.wait(0.25)
        end
        if #found==0 then afgStatusL.Text="Nothing found — try again."; afgStatusL.TextColor3=C.red
        else afgStatusL.Text="Done! Found "..#found.." game(s) with 0 players & 0 visits."; afgStatusL.TextColor3=C.green end
        afgActive=false; afgBtn.Text="Search Now"; tween(afgBtn,{BackgroundColor3=C.tealStroke},0.15)
    end)
end
afgBtn.MouseButton1Click:Connect(doAFGSearch)

